{
    "id": "per",
    "label": { "en-gb": "Person" },
    "labelPlural": { "en-gb": "People" },
    "description": { "en-gb": "..." },
    "dataItems": [
        { "id": "entId", "label": { "en-gb": "Entity Id" }, "type": "string", "description": { "en-gb": "The unique identifier assigned to the person." } },
        {
            "id": "evtMom",
            "label": { "en-gb": "Event Moment" },
            "type": "moment",
            "description": { "en-gb": "The effective moment of the event. See the events for an explanation of how the effective moment is interpreted for each event." }
        },
        {
            "id": "evtSeq",
            "label": { "en-gb": "Event Sequence" },
            "type": "number",
            "description": {
                "en-gb": "The sequence of the event within the moment. If multiple events occur at the same moment, then we can use this data item to define the sequence."
            }
        },
        {
            "id": "evtId",
            "label": { "en-gb": "Event Id" },
            "type": "string",
            "description": { "en-gb": "The event identifier. See the events for a list of acceptable identifiers." }
        },
        { "id": "perId", "label": { "en-gb": "Personal Id" }, "type": "string", "description": { "en-gb": "The person's personal or national identifier." } },
        { "id": "famNames", "label": { "en-gb": "Family Names" }, "type": "string", "description": { "en-gb": "The person's family names." } },
        { "id": "givNames", "label": { "en-gb": "Given Names" }, "type": "string", "description": { "en-gb": "The person's given names." } },
        { "id": "bthDate", "label": { "en-gb": "Date of Birth" }, "type": "day(first('brn'))" },
        { "id": "dthDate", "label": { "en-gb": "Date of Death" }, "type": "day(first('dec'))" },
        { "id": "age", "type": "lookup('perAge', ageYear(bthDate))" },
        { "id": "ctryBth", "type": "lookup('core.geographic.geoCountry')" },
        { "id": "eduLvl", "type": "lookup('perEduLvl')" },
        { "id": "ethGrp", "type": "lookup('perEthGrp')" },
        { "id": "gen", "type": "lookup('perGen', year(bthDate))" },
        { "id": "gdr", "type": "lookup('perGdr')" },
        { "id": "homeLoc", "label": { "en-gb": "Home Location" }, "type": "lookup('core.geographic.geoCity')" },
        { "id": "langPref", "label": { "en-gb": "Language (Preferred)" }, "type": "lookup('perLang')" },
        { "id": "marSts", "type": "lookup('perMarSts')" },
        { "id": "min", "type": "lookup('perMin')" },
        { "id": "physAb", "type": "lookup('perPhyAb')" },
        { "id": "resLoc", "label": { "en-gb": "Residential Location" }, "type": "lookup('core.geographic.geoCity')" },
        { "id": "resNat", "label": { "en-gb": "Residential Nationality" }, "type": "lookup('perNat')" },
        { "id": "sexOri", "type": "lookup('perSexOri')" },
        { "id": "vetSts", "type": "lookup('perVetSts')" }
    ],
    "events": [
        { "id": "brn", "label": { "en-gb": "Born" }, "type": "activation", "description": { "en-gb": "The moment the person was born." } },
        { "id": "rec", "label": { "en-gb": "Recognised" }, "type": "recognition", "description": { "en-gb": "The moment the person was recognised." } },
        { "id": "upd", "label": { "en-gb": "Updated" }, "type": "modification", "description": { "en-gb": "The moment from which the modification applied." } },
        { "id": "der", "label": { "en-gb": "Derecognised" }, "type": "derecognition", "description": { "en-gb": "The moment from which the person was no longer recognised." } },
        { "id": "dec", "label": { "en-gb": "Deceased" }, "type": "closing", "description": { "en-gb": "The moment from which the person was no longer alive." } },
        { "id": "del", "label": { "en-gb": "Deleted" }, "type": "deletion", "description": { "en-gb": "The moment from which the person entity was deleted." } }
    ],
    "primaryMeasures": [
        { "id": "opnCnt", "label": { "en-gb": "Person Opening Count" }, "description": { "en-gb": "The number of people present at the opening moment of a reporting period." } },
        { "id": "strCnt", "label": { "en-gb": "Person Starting Count" }, "description": { "en-gb": "The number of people present at the start of a reporting period." } },
        {
            "id": "strInCnt",
            "label": { "en-gb": "Person Starting In Count" },
            "description": { "en-gb": "The number of people recognised at the first moment of a reporting period." }
        },
        { "id": "durInCnt", "label": { "en-gb": "Person During In Count" }, "description": { "en-gb": "The number of people recognised during a reporting period." } },
        { "id": "durCnt", "label": { "en-gb": "Person During Count" }, "description": { "en-gb": "The number of people present at any moment within the reporting period." } },
        { "id": "wtdCnt", "label": { "en-gb": "Person Weighted Count" }, "description": { "en-gb": "The weighted number of people present within a reporting period." } },
        { "id": "durOutCnt", "label": { "en-gb": "Person During Out Count" }, "description": { "en-gb": "The number of people derecognised during a reporting period." } },
        {
            "id": "endOutCnt",
            "label": { "en-gb": "Person Ending Out Count" },
            "description": { "en-gb": "The number of people derecognised at the last moment of a reporting period." }
        },
        { "id": "endCnt", "label": { "en-gb": "Person Ending Count" }, "description": { "en-gb": "The number of people present at the end of a reporting period." } },
        { "id": "clsCnt", "label": { "en-gb": "Person Closing Count" }, "description": { "en-gb": "The number of people present at the closing moment of a reporting period." } }
    ]
}
