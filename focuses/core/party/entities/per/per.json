{
    "id": "per",
    "label": { "en-gb": "Person" },
    "labelPlural": { "en-gb": "People" },
    "description": { "en-gb": "..." },
    "dataItems": [
        { "id": "entId", "label": { "en-gb": "Entity Id" }, "description": { "en-gb": "The unique identifier assigned to the person." } },
        {
            "id": "evtMom",
            "label": { "en-gb": "Event Moment" },
            "content": "moment",
            "description": { "en-gb": "The effective moment of the event. See the events for an explanation of how the effective moment is interpreted for each event." }
        },
        {
            "id": "evtSeq",
            "label": { "en-gb": "Event Sequence" },
            "content": "number",
            "description": {
                "en-gb": "The sequence of the event within the moment. If multiple events occur at the same moment, then we can use this data item to define the sequence."
            }
        },
        {
            "id": "evtId",
            "label": { "en-gb": "Event Id" },
            "description": { "en-gb": "The event identifier. See the events for a list of acceptable identifiers." }
        },
        { "id": "perId", "label": { "en-gb": "Personal Id" }, "description": { "en-gb": "The person's personal or national identifier." } },
        { "id": "famNames", "label": { "en-gb": "Family Names" }, "description": { "en-gb": "The person's family names." } },
        { "id": "givNames", "label": { "en-gb": "Given Names" }, "description": { "en-gb": "The person's given names." } },
        { "id": "bthDate", "label": { "en-gb": "Date of Birth" }, "content": "day(first('brn'))" },
        { "id": "dthDate", "label": { "en-gb": "Date of Death" }, "content": "day(first('dec'))" },
        { "id": "age", "content": "ageYears(bthDate)", "lookup": "perAge" },
        { "id": "ctryBth", "lookup": "core.geographic.geoCountry" },
        { "id": "eduLvl", "lookup": "perEduLvl" },
        { "id": "ethGrp", "lookup": "perEthGrp" },
        { "id": "gen", "content": "year(bthDate)", "lookup": "perGen" },
        { "id": "gdr", "lookup": "perGdr" },
        { "id": "homeLoc", "label": { "en-gb": "Home Location" }, "lookup": "core.geographic.geoCity" },
        { "id": "langPref", "label": { "en-gb": "Language (Preferred)" }, "lookup": "perLang" },
        { "id": "marSts", "lookup": "perMarSts" },
        { "id": "min", "lookup": "perMin" },
        { "id": "physAb", "lookup": "perPhyAb" },
        { "id": "resLoc", "label": { "en-gb": "Residential Location" }, "lookup": "core.geographic.geoCity" },
        { "id": "resNat", "label": { "en-gb": "Residential Nationality" }, "lookup": "perNat" },
        { "id": "sexOri", "lookup": "perSexOri" },
        { "id": "vetSts", "lookup": "perVetSts" }
    ],
    "events": [
        { "mapTo": "activation", "id": "brn", "label": { "en-gb": "Born" }, "description": { "en-gb": "The moment the person was born." } },
        { "mapTo": "recognition", "id": "rec", "label": { "en-gb": "Recognised" }, "description": { "en-gb": "The moment the person was recognised." } },
        { "mapTo": "modification", "id": "upd", "label": { "en-gb": "Updated" }, "description": { "en-gb": "The moment from which the modification applied." } },
        { "mapTo": "derecognition", "id": "der", "label": { "en-gb": "Derecognised" }, "description": { "en-gb": "The moment from which the person was no longer recognised." } },
        { "mapTo": "closing", "id": "dec", "label": { "en-gb": "Deceased" }, "description": { "en-gb": "The moment from which the person was no longer alive." } },
        { "mapTo": "deletion", "id": "del", "label": { "en-gb": "Deleted" }, "description": { "en-gb": "The moment from which the person entity was deleted." } }
    ],
    "primaryMeasures": [
        {
            "mapTo": "openCount",
            "label": { "en-gb": "Person Opening Count" },
            "description": { "en-gb": "The number of people present at the opening moment of a reporting period." }
        },
        { "mapTo": "startCount", "label": { "en-gb": "Person Starting Count" }, "description": { "en-gb": "The number of people present at the start of a reporting period." } },
        {
            "mapTo": "startInCount",
            "label": { "en-gb": "Person Starting In Count" },
            "description": { "en-gb": "The number of people recognised at the first moment of a reporting period." }
        },
        { "mapTo": "duringInCount", "label": { "en-gb": "Person During In Count" }, "description": { "en-gb": "The number of people recognised during a reporting period." } },
        {
            "mapTo": "duringCount",
            "label": { "en-gb": "Person During Count" },
            "description": { "en-gb": "The number of people present at any moment within the reporting period." }
        },
        { "mapTo": "weightedCount", "label": { "en-gb": "Person Weighted Count" }, "description": { "en-gb": "The weighted number of people present within a reporting period." } },
        { "mapTo": "duringOutCount", "label": { "en-gb": "Person During Out Count" }, "description": { "en-gb": "The number of people derecognised during a reporting period." } },
        {
            "mapTo": "endOutCount",
            "label": { "en-gb": "Person Ending Out Count" },
            "description": { "en-gb": "The number of people derecognised at the last moment of a reporting period." }
        },
        { "mapTo": "endCount", "label": { "en-gb": "Person Ending Count" }, "description": { "en-gb": "The number of people present at the end of a reporting period." } },
        {
            "mapTo": "closeCount",
            "label": { "en-gb": "Person Closing Count" },
            "description": { "en-gb": "The number of people present at the closing moment of a reporting period." }
        }
    ]
}
