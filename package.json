{
    "name": "datapos-context-default",
    "license": "MIT",
    "private": true,
    "type": "module",
    "version": "0.0.95",
    "devDependencies": {
        "@datapos/datapos-development": "^0.3.84",
        "@datapos/datapos-shared": "^0.3.207",
        "@types/node": "^24.10.1",
        "@typescript-eslint/eslint-plugin": "^8.46.4",
        "@typescript-eslint/parser": "^8.46.4",
        "dotenv": "^17.2.3",
        "eslint": "^9.39.1",
        "eslint-plugin-import": "^2.32.0",
        "jiti": "^2.6.1",
        "jszip": "^3.10.1",
        "kdbush": "^4.0.2",
        "license-report": "^6.8.1",
        "license-report-check": "^0.1.2",
        "nanoid": "^5.1.6",
        "npm-check-updates": "^19.1.2",
        "prettier": "^3.6.2",
        "retire": "^5.3.0",
        "typescript": "^5.9.3",
        "vite": "^7.2.2",
        "vite-plugin-dts": "^4.5.4"
    },
    "scripts": {
        "audit": "npm audit",
        "build": "vite build",
        "buildConfig": "node -e \"import('@datapos/datapos-development').then(m => m.buildConfig())\"",
        "bumpVersion": "node -e \"import('@datapos/datapos-development').then(m => m.bumpVersion())\"",
        "check": "npm outdated; npm-check-updates -i && retire",
        "document": "license-report --only=prod,peer > LICENSES.json && license-report-check --source ./LICENSES.json --allowed 'MIT' --allowed 'n/a' --allowed 'Apache-2.0' --output=table",
        "format": "prettier --write *.ts",
        "lint": "eslint src/**/*.ts",
        "release": "npm run syncWithGitHub && npm run build && npm run uploadModuleToR2 && npm run uploadModuleConfig",
        "sync:withGitHub": "npm run bumpVersion && npm run buildConfig && node -e \"import('@datapos/datapos-development').then(m => m.syncWithGitHub())\"",
        "test": "echo \"***** TEST SCRIPT NOT IMPLEMENTED. *****\"",
        "updateDependencies": "npm run updateDevelopment && npm run updateShared",
        "updateDevelopment": "npm install --save-dev @datapos/datapos-development@latest",
        "updateShared": "npm install @datapos/datapos-shared@latest",
        "uploadModuleConfig": "node -e \"import('@datapos/datapos-development').then(m => m.uploadModuleConfig())\"",
        "uploadModuleToR2": "node -e \"import('@datapos/datapos-development').then(m => m.uploadModuleToR2('datapos-context-default.es.js', 'datapos-engine-eu/contexts/datapos-context-default.es.js'))\"",
        "retrieveGeoData": "node ./helpers/retrieveGeoData.js",
        "transformFinData": "node ./helpers/transformFinData.js",
        "transformGeoData": "node ./helpers/transformGeoData.js",
        "transformPerData": "node ./helpers/transformPerData.js",
        "buildGeoDimensions": "node ./helpers/buildGeoDimensions.js"
    }
}