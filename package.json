{
    "name": "@dpuse/dpuse-context-default",
    "version": "0.0.105",
    "description": "A TypeScript library that implements the default context.",
    "license": "MIT",
    "author": "Jonathan Terrell <terrell.jm@gmail.com>",
    "private": false,
    "type": "module",
    "homepage": "https://www.dpuse.app",
    "repository": {
        "type": "git",
        "url": "https://github.com/data-positioning/dpuse-context-default.git"
    },
    "bugs": {
        "url": "https://github.com/data-positioning/dpuse-context-default/issues"
    },
    "module": "./dist/dpuse-context-default.es.js",
    "types": "./dist/types/src/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/dpuse-context-default.es.js",
            "types": "./dist/types/src/index.d.ts"
        }
    },
    "files": [
        "dist"
    ],
    "dependencies": {
        "@dpuse/dpuse-shared": "^0.3.595"
    },
    "devDependencies": {
        "@dpuse/dpuse-development": "^0.3.486",
        "@dpuse/eslint-config-dpuse": "^1.0.55",
        "@types/node": "^25.5.0",
        "@typescript-eslint/eslint-plugin": "^8.57.2",
        "@typescript-eslint/parser": "^8.57.2",
        "dotenv": "^17.3.1",
        "eslint": "^9.39.4",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-security": "^4.0.0",
        "eslint-plugin-sonarjs": "^4.0.2",
        "eslint-plugin-unicorn": "^63.0.0",
        "jiti": "^2.6.1",
        "jszip": "^3.10.1",
        "kdbush": "^4.0.2",
        "license-downloader": "^1.3.3",
        "license-report": "^6.8.2",
        "license-report-check": "^0.1.2",
        "license-report-recursive": "^6.8.3",
        "nanoid": "^5.1.7",
        "npm-check-updates": "^19.6.5",
        "owasp-dependency-check": "^1.0.1",
        "prettier": "^3.8.1",
        "rollup-plugin-visualizer": "^7.0.1",
        "typescript": "^5.9.3",
        "vite": "^8.0.2",
        "vite-plugin-dts": "^4.5.4",
        "vitest": "^4.1.1"
    },
    "scripts": {
        "audit": "op run --env-file=.env -- node -e \"import('@dpuse/dpuse-development').then(m => m.auditDependencies())\"",
        "build": "node -e \"import('@dpuse/dpuse-development').then(m => m.buildProject())\"",
        "check": "node -e \"import('@dpuse/dpuse-development').then(m => m.checkDependencies())\"",
        "document": "op run --env-file=.env -- node -e \"import('@dpuse/dpuse-development').then(m => m.documentDependencies(['Apache-2.0','MIT']))\"",
        "format": "node -e \"import('@dpuse/dpuse-development').then(m => m.formatCode())\"",
        "lint": "node -e \"import('@dpuse/dpuse-development').then(m => m.lintCode())\"",
        "release": "op run --env-file=.env -- node -e \"import('@dpuse/dpuse-development').then(m => m.releaseProject())\"",
        "sync": "node -e \"import('@dpuse/dpuse-development').then(m => m.syncProjectWithGitHub())\"",
        "test": "node -e \"import('@dpuse/dpuse-development').then(m => m.testProject())\"",
        "update": "node -e \"import('@dpuse/dpuse-development').then(m => m.updateDPUseDependencies(['development', 'eslint', 'shared']))\"",
        "__retrieveGeoData": "node ./helpers/retrieveGeoData.js",
        "__transformFinData": "node ./helpers/transformFinData.js",
        "__transformGeoData": "node ./helpers/transformGeoData.js",
        "__transformPerData": "node ./helpers/transformPerData.js",
        "__buildGeoDimensions": "node ./helpers/buildGeoDimensions.js"
    }
}