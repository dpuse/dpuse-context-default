{
    "name": "datapos-context-default",
    "license": "MIT",
    "private": true,
    "type": "module",
    "version": "0.0.23",
    "peerDependencies": {
        "@datapos/datapos-shared": "^0.3.24",
        "nanoid": "^5.1.5"
    },
    "devDependencies": {
        "@datapos/datapos-development": "^0.3.17",
        "@eslint/js": "^9.28.0",
        "@types/node": "^22.15.30",
        "dotenv": "^17.2.2",
        "eslint": "^9.28.0",
        "globals": "^16.2.0",
        "prettier": "^3.5.3",
        "typescript": "^5.8.3",
        "typescript-eslint": "^8.33.1",
        "vite": "^6.3.5",
        "vite-plugin-dts": "^4.5.4"
    },
    "scripts": {
        "build": "npx vite build",
        "buildConfig": "node -e \"import('@datapos/datapos-development').then(m => m.buildConfig())\"",
        "bumpVersion": "node -e \"import('@datapos/datapos-development').then(m => m.bumpVersion())\"",
        "check": "npx npm-check-updates && npm outdated",
        "format": "prettier --write *.ts",
        "lint": "npx eslint src/**/*.ts",
        "release": "npm run syncWithGitHub && npm run build && npm run uploadModuleToR2 && npm run uploadModuleConfig",
        "retrieveCountryDataFromCountrylayer": "node ./helpers/retrieveCountryDataFromCountrylayer.js",
        "retrieveCountryDataFromCountryRest": "node ./helpers/retrieveCountryDataFromCountryRest.js",
        "buildCountryDimensions": "node ./helpers/buildCountryDimensions.js",
        "syncWithGitHub": "npm run bumpVersion && npm run buildConfig && node -e \"import('@datapos/datapos-development').then(m => m.syncWithGitHub())\"",
        "updateDependencies": "npm run updateDevelopment && npm run updateShared",
        "updateDevelopment": "npm install --save-dev @datapos/datapos-development@latest",
        "updateShared": "npm install @datapos/datapos-shared@latest",
        "uploadModuleConfig": "node -e \"import('@datapos/datapos-development').then(m => m.uploadModuleConfig())\"",
        "uploadModuleToR2": "node -e \"import('@datapos/datapos-development').then(m => m.uploadModuleToR2('datapos-connector-file-store-emulator.es.js', 'datapos-engine-eu/connectors/datapos-connector-file-store-emulator.es.js'))\""
    }
}